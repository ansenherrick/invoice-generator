{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/invoice",
      "destination": "/index.html"
    },
    {
      "source": "/clock",
      "destination": "/index.html"
    },
    {
      "source": "/profile",
      "destination": "/index.html"
    }
  ]
}
